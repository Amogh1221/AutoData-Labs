OLLAMA_MODEL="qwen2.5:7b-instruct"

# ── Cloud Mode ──────────────────────────────────────────────────────────────
# Set CLOUD_MODE=true to use a cloud LLM instead of local Ollama.
# Set CLOUD_MODE=false (or remove) to use local Ollama.
CLOUD_MODE=true

# ── Cloud Provider ──────────────────────────────────────────────────────────
# CLOUD_PROVIDER=groq   → Groq API (FREE, fast, supports Llama 3.1 8B)
# CLOUD_PROVIDER=hf     → Hugging Face router (requires HF credits for gated models)
CLOUD_PROVIDER=groq

# ── Groq Settings (used when CLOUD_PROVIDER=groq) ───────────────────────────
# Get a FREE API key at: https://console.groq.com  (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Hugging Face Settings (used when CLOUD_PROVIDER=hf) ─────────────────────
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
# For gated Meta/Llama models: use 'nebius'
# For open models (Qwen, Mistral, etc.): use 'hf-inference' (free)
HF_PROVIDER=nebius

# AutoData Labs Configuration

# Mode Selection: set to true to use cloud models (Hugging Face), false for local Ollama
CLOUD_MODE=false

# Ollama Settings (used when CLOUD_MODE=false)
OLLAMA_MODEL=qwen2.5:7b-instruct

# Hugging Face Settings (used when CLOUD_MODE=true)
HF_API_KEY=your_huggingface_api_key_here
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# HF Inference Provider (router.huggingface.co/{provider}/v1/chat/completions)
# For gated Meta/Llama models: use 'novita' or 'nebius'
# For open models (Qwen, Mistral, etc.): use 'hf-inference' (free)
HF_PROVIDER=novita
